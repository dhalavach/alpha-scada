{
  "title": "Alpha SCADA Messaging",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["alpha-scada", "messaging"],
  "panels": [
    {
      "title": "Service Scrape Health",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"alpha-scada-services\"}",
          "legendFormat": "{{ instance }}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      }
    },
    {
      "title": "Wolverine Outbox Depth",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "alpha_scada_wolverine_outbox_depth",
          "legendFormat": "{{ service }}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      }
    },
    {
      "title": "Wolverine Error Queue Depth",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "alpha_scada_wolverine_error_queue_depth",
          "legendFormat": "{{ service }}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      }
    },
    {
      "title": "Alarm Outbox State",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "alpha_scada_alarm_outbox_pending",
          "legendFormat": "pending"
        },
        {
          "expr": "alpha_scada_alarm_outbox_poison",
          "legendFormat": "poison"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      }
    },
    {
      "title": "Telemetry Ingestion Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (outcome) (rate(alpha_scada_telemetry_ingestion_messages_total[5m]))",
          "legendFormat": "{{ outcome }}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      }
    },
    {
      "title": "Telemetry Ingestion p95",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(alpha_scada_telemetry_ingestion_processing_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      }
    }
  ]
}
