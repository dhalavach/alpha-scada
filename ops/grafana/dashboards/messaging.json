{
  "title": "Alpha SCADA Messaging",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["alpha-scada", "messaging"],
  "panels": [
    {
      "title": "Service Scrape Health",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"alpha-scada-services\"}",
          "legendFormat": "{{ instance }}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      }
    },
    {
      "title": "Wolverine Outbox Depth",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "alpha_scada_wolverine_outbox_depth",
          "legendFormat": "{{ service }}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      }
    },
    {
      "title": "Wolverine Error Queue Depth",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "alpha_scada_wolverine_error_queue_depth",
          "legendFormat": "{{ service }}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      }
    },
    {
      "title": "MQTT DLQ Depth",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "alpha_scada_mqtt_dlq_depth",
          "legendFormat": "{{ service }}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      }
    },
    {
      "title": "MQTT Subscribe Lag",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "alpha_scada_mqtt_subscribe_lag_seconds",
          "legendFormat": "{{ service }}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      }
    },
    {
      "title": "Telemetry Samples Written",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(alpha_scada_telemetry_samples_written_total[5m])",
          "legendFormat": "{{ service }}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      }
    }
  ]
}
